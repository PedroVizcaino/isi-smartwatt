# Usar la imagen oficial de Nginx basada en Alpine para ligereza
FROM nginx:alpine

# Eliminar la configuración por defecto de Nginx
RUN rm /etc/nginx/conf.d/default.conf

# Copiar nuestra configuración personalizada
COPY nginx.conf /etc/nginx/conf.d/

# Copiar los archivos estáticos del frontend al directorio de Nginx
COPY frontend/ /usr/share/nginx/html/

# Exponer el puerto 80
EXPOSE 80

# Nginx se inicia automáticamente por defecto
